# ============================================================
# RAG BUSINESS ASSISTANT — CONFIGURAZIONE
# ============================================================

# === OBBLIGATORIE ===
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxx
REPOS_HOST_PATH=/percorso/assoluto/alla/tua/cartella/repos

# === MODELLO GEMINI ===
GEMINI_MODEL=gemini-2.5-flash

# === QDRANT ===
QDRANT_PORT=6333
COLLECTION_NAME=codebase

# === RAG ===
MAX_RISULTATI=8
CHUNK_MAX_CHARS=1500
# Reranking: risultati più precisi (leggermente più lento)
ENABLE_RERANKING=true
# Candidati da valutare prima del reranking (deve essere > MAX_RISULTATI)
RERANK_CANDIDATES=30
# Peso vettoriale vs full-text (0.0 = solo text, 1.0 = solo vettoriale)
HYBRID_ALPHA=0.7

# === RESILIENZA ===
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=1.0
RATE_LIMIT_PER_MINUTE=30

# === OSSERVABILITÀ ===
LOG_LEVEL=INFO
ENABLE_QUERY_LOG=true

# === PORTE ===
WEBUI_PORT=3000
RAG_PROXY_PORT=8001
