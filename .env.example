# ============================================================
# RAG BUSINESS ASSISTANT — CONFIGURATION
# ============================================================

# === REQUIRED ===
REPOS_HOST_PATH=/absolute/path/to/your/repos/folder

# === LLM PROVIDER ===
# "gemini" (default) or "openai" (also works with GitHub Copilot API)
LLM_PROVIDER=gemini

# --- Gemini (LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI / GitHub Copilot (LLM_PROVIDER=openai) ---
# ----- ( to be tested )
# For GitHub Copilot: OPENAI_BASE_URL=https://api.githubcopilot.com
#                     OPENAI_API_KEY=<your GitHub token>
#                     OPENAI_MODEL=gpt-4o
#OPENAI_API_KEY=
#OPENAI_BASE_URL=https://api.openai.com/v1
#OPENAI_MODEL=gpt-4o

# === QDRANT ===
QDRANT_PORT=6333
COLLECTION_NAME=codebase

# === RAG ===
MAX_RISULTATI=8
CHUNK_MAX_CHARS=1500
# Overlap between consecutive chunks (improves context at boundaries)
CHUNK_OVERLAP_CHARS=200
# Reranking: more accurate results (slightly slower)
ENABLE_RERANKING=true
# Candidates to evaluate before reranking (must be > MAX_RISULTATI)
RERANK_CANDIDATES=30
# Vector vs full-text weight (0.0 = text only, 1.0 = vector only)
# 0.65 balances well for code: keyword match is important for function/variable names
HYBRID_ALPHA=0.65
# Cross-encoder reranker model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Max text length passed to the reranker (characters)
RERANK_TRUNCATE=1024

# === MODELS ===
# Embedding model — bge-base-en-v1.5 excels on code and text in MTEB benchmarks
# Alternatives:
#   all-mpnet-base-v2           — good general purpose (768 dim, no prefix)
#   jinaai/jina-embeddings-v2-base-code — code-specific (768 dim, 8K context)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# Query prefix for instruction-following models (BGE requires it for optimal results)
# Leave empty for models without prefix (e.g. all-mpnet-base-v2)
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages: 

# === INDEXING ===
# Batch size for indexing (64 is safe for MacBook Pro M3/M4)
BATCH_SIZE=64
# HNSW parameters (m = connections per node, ef = construction candidates)
HNSW_M=16
HNSW_EF=128
# Scalar INT8 quantization (reduces memory, speeds up search)
ENABLE_QUANTIZATION=true

# === INDEXING MODE ===
# Set to true to force full reindex (drop + recreate collection)
# Default is incremental: only changed files are re-indexed
FORCE_REINDEX=false

# === SYSTEM PROMPT ===
# Custom system prompt (leave empty for default)
# SYSTEM_PROMPT=You are an expert assistant...

# === QUERY LOG ===
# Max query log file size before rotation (MB)
QUERY_LOG_MAX_SIZE_MB=50

# === RESILIENCE ===
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=1.0
RATE_LIMIT_PER_MINUTE=30

# === OBSERVABILITY ===
LOG_LEVEL=INFO
ENABLE_QUERY_LOG=true

# === PORTS ===
WEBUI_PORT=3000
RAG_PROXY_PORT=8001
