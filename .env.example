# ============================================================
# RAG BUSINESS ASSISTANT — CONFIGURAZIONE
# ============================================================

# === OBBLIGATORIE ===
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxx
REPOS_HOST_PATH=/percorso/assoluto/alla/tua/cartella/repos

# === MODELLO GEMINI ===
GEMINI_MODEL=gemini-2.5-flash

# === QDRANT ===
QDRANT_PORT=6333
COLLECTION_NAME=codebase

# === RAG ===
MAX_RISULTATI=8
CHUNK_MAX_CHARS=1500
# Sovrapposizione tra chunk consecutivi (migliora il contesto ai confini)
CHUNK_OVERLAP_CHARS=200
# Reranking: risultati più precisi (leggermente più lento)
ENABLE_RERANKING=true
# Candidati da valutare prima del reranking (deve essere > MAX_RISULTATI)
RERANK_CANDIDATES=30
# Peso vettoriale vs full-text (0.0 = solo text, 1.0 = solo vettoriale)
# 0.65 bilancia bene per codice: keyword match è importante per nomi funzioni/variabili
HYBRID_ALPHA=0.65
# Modello reranker cross-encoder
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Lunghezza massima del testo passato al reranker (caratteri)
RERANK_TRUNCATE=512

# === MODELLI ===
# Modello embedding — bge-base-en-v1.5 eccelle su codice e testo nei benchmark MTEB
# Alternative:
#   all-mpnet-base-v2           — buon general purpose (768 dim, nessun prefisso)
#   jinaai/jina-embeddings-v2-base-code — specifico per codice (768 dim, contesto 8K)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# Prefisso query per modelli instruction-following (BGE lo richiede per risultati ottimali)
# Lasciare vuoto per modelli senza prefisso (es. all-mpnet-base-v2)
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages: 

# === INDICIZZAZIONE ===
# Dimensione batch per l'indicizzazione (64 è sicuro per MacBook Pro M3/M4)
BATCH_SIZE=64
# Parametri HNSW (m = connessioni per nodo, ef = candidati in costruzione)
HNSW_M=16
HNSW_EF=128
# Quantizzazione scalare INT8 (riduce memoria, velocizza la ricerca)
ENABLE_QUANTIZATION=true

# === RESILIENZA ===
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=1.0
RATE_LIMIT_PER_MINUTE=30

# === OSSERVABILITÀ ===
LOG_LEVEL=INFO
ENABLE_QUERY_LOG=true

# === PORTE ===
WEBUI_PORT=3000
RAG_PROXY_PORT=8001
